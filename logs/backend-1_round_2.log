+/// Helper to create a TestServer with the townhall router
+async fn create_test_app(name: &str) -> Result<(TestServer, TownhallTestServer), Box<dyn std::error::Error>> {
+    let server = TownhallTestServer::new(name).await?;
+    let state = Arc::new(AppState { town: server.town.clone() });
+    let router = create_router(state);
+    let test_server = TestServer::new(router);
+    Ok((test_server, server))
+}
+
+/// Test GET /healthz returns healthy status
+#[tokio::test]
+async fn test_api_healthz() -> Result<(), Box<dyn std::error::Error>> {
+    let (app, _server) = create_test_app("healthz-test").await?;
+
+    let response = app.get("/healthz").await;
+    response.assert_status_ok();
+
+    let body: serde_json::Value = response.json();
+    assert_eq!(body["status"], "ok");
+
+    Ok(())
+}
+
